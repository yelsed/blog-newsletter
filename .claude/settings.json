{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.php)|Write(*.php)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/php-quality-check.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
